{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "ESNEXT"],
    "baseUrl": "./src",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "noEmit": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["src/cache.ts", "src/shared.ts", "src/check_expired.ts", "src/effect.ts", "src/proxy", "src/extends"]
}
